#!/usr/bin/env bash
# ─────────────────────────────────────────────
#  Proxy Pulse — Run / Stop Script
#  Auto-downloads the latest release binary
#  Self-updates when a newer version is available
#  Works on Linux, macOS, and Windows (Git Bash/MSYS2/WSL)
# ─────────────────────────────────────────────
set -euo pipefail

REPO="OpenInfra-Labs/Proxy-Pulse"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT_PATH="$SCRIPT_DIR/$(basename "$0")"
PID_FILE="$SCRIPT_DIR/.proxy-pulse.pid"
VERSION_FILE="$SCRIPT_DIR/.proxy-pulse.version"

# ─── Detect platform ───
detect_platform() {
    local os arch
    os="$(uname -s | tr '[:upper:]' '[:lower:]')"
    arch="$(uname -m)"

    case "$os" in
        linux)          OS_NAME="linux" ;;
        darwin)         OS_NAME="darwin" ;;
        mingw*|msys*|cygwin*) OS_NAME="windows" ;;
        *)              echo "Unsupported OS: $os" >&2; exit 1 ;;
    esac

    case "$arch" in
        x86_64|amd64)   ARCH_NAME="amd64" ;;
        aarch64|arm64)  ARCH_NAME="arm64" ;;
        *)              echo "Unsupported architecture: $arch" >&2; exit 1 ;;
    esac

    ARTIFACT_NAME="proxy-pulse-${OS_NAME}-${ARCH_NAME}"

    if [ "$OS_NAME" = "windows" ]; then
        BINARY="$SCRIPT_DIR/proxy-pulse.exe"
        PKG_EXT="zip"
    else
        BINARY="$SCRIPT_DIR/proxy-pulse"
        PKG_EXT="tar.gz"
    fi
}

# ─── Self-update: check if run script itself has a newer version ───
self_update() {
    echo "Checking for run script updates..."
    local remote_url="https://raw.githubusercontent.com/${REPO}/main/run"
    local tmp_script
    tmp_script="$(mktemp)"

    if ! curl -fsSL -o "$tmp_script" "$remote_url"; then
        echo "Warning: Could not check for script updates." >&2
        rm -f "$tmp_script"
        return 0
    fi

    if ! diff -q "$SCRIPT_PATH" "$tmp_script" > /dev/null 2>&1; then
        echo "Run script has been updated. Applying update..."
        cp "$tmp_script" "$SCRIPT_PATH"
        chmod +x "$SCRIPT_PATH"
        rm -f "$tmp_script"
        echo "Restarting with updated script..."
        exec "$SCRIPT_PATH" "$@"
    fi

    rm -f "$tmp_script"
    echo "Run script is up to date."
}

# ─── Get latest release tag from GitHub ───
get_latest_version() {
    curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
        | grep '"tag_name"' \
        | head -1 \
        | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/'
}

# ─── Download release binary for a specific version ───
download_binary() {
    local version="$1"
    local pkg_file="${ARTIFACT_NAME}.${PKG_EXT}"
    local download_url="https://github.com/${REPO}/releases/download/${version}/${pkg_file}"

    echo "Downloading ${pkg_file} (${version})..."
    if ! curl -fsSL -o "$SCRIPT_DIR/$pkg_file" "$download_url"; then
        echo "Error: Failed to download ${download_url}" >&2
        exit 1
    fi

    echo "Extracting..."
    if [ "$PKG_EXT" = "zip" ]; then
        unzip -o "$SCRIPT_DIR/$pkg_file" -d "$SCRIPT_DIR" > /dev/null
    else
        tar xzf "$SCRIPT_DIR/$pkg_file" -C "$SCRIPT_DIR"
        mv "$SCRIPT_DIR/$ARTIFACT_NAME" "$BINARY"
        chmod +x "$BINARY"
    fi
    rm -f "$SCRIPT_DIR/$pkg_file"

    # Save installed version
    echo "$version" > "$VERSION_FILE"
    echo "Binary installed: $BINARY (${version})"
}

# ─── Check and update binary if a newer version is available ───
check_binary_update() {
    local latest_version
    latest_version="$(get_latest_version)"

    if [ -z "$latest_version" ]; then
        echo "Warning: Could not fetch latest version info." >&2
        return 0
    fi

    # No binary or no version file → download
    if [ ! -f "$BINARY" ] || [ ! -f "$VERSION_FILE" ]; then
        download_binary "$latest_version"
        return 0
    fi

    local current_version
    current_version="$(cat "$VERSION_FILE")"

    if [ "$current_version" != "$latest_version" ]; then
        echo "New version available: ${current_version} → ${latest_version}"
        download_binary "$latest_version"
    else
        echo "Binary is up to date (${current_version})."
    fi
}

# ─── Open browser if possible ───
open_browser() {
    local url="$1"
    if command -v xdg-open > /dev/null 2>&1; then
        # Linux with desktop
        xdg-open "$url" > /dev/null 2>&1 &
    elif command -v open > /dev/null 2>&1; then
        # macOS
        open "$url"
    elif command -v start > /dev/null 2>&1; then
        # Windows (Git Bash / MSYS2)
        start "$url"
    elif [ -n "${BROWSER:-}" ]; then
        "$BROWSER" "$url" > /dev/null 2>&1 &
    else
        # No browser detected (headless server) — skip silently
        return 0
    fi
    echo "Browser opened: $url"
}

# ─── Stop ───
stop_service() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Proxy Pulse is not running (no PID file found)."
        return 0
    fi

    local pid
    pid="$(cat "$PID_FILE")"

    if kill -0 "$pid" 2>/dev/null; then
        echo "Stopping Proxy Pulse (PID: $pid)..."
        kill "$pid"
        local i=0
        while kill -0 "$pid" 2>/dev/null && [ $i -lt 10 ]; do
            sleep 1
            i=$((i + 1))
        done
        if kill -0 "$pid" 2>/dev/null; then
            echo "Force killing..."
            kill -9 "$pid" 2>/dev/null || true
        fi
        rm -f "$PID_FILE"
        echo "Proxy Pulse stopped."
    else
        echo "Proxy Pulse is not running (stale PID: $pid)."
        rm -f "$PID_FILE"
    fi
}

# ─── Start ───
start_service() {
    local was_running=false

    if [ -f "$PID_FILE" ]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            was_running=true
            echo "Proxy Pulse is running (PID: $pid). Checking for updates before restart..."
        else
            rm -f "$PID_FILE"
        fi
    fi

    # Self-update the run script first
    self_update "$@"

    # Check for binary updates (download or upgrade)
    check_binary_update

    # Stop old process if it was running
    if [ "$was_running" = true ]; then
        stop_service
    fi

    echo "Starting Proxy Pulse..."
    cd "$SCRIPT_DIR"
    nohup "$BINARY" >> "$SCRIPT_DIR/proxy-pulse.log" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    if [ "$was_running" = true ]; then
        echo "Proxy Pulse restarted (PID: $pid)."
    else
        echo "Proxy Pulse started in background (PID: $pid)."
    fi
    echo "Log: $SCRIPT_DIR/proxy-pulse.log"

    # Auto-open browser (only on fresh start)
    if [ "$was_running" = false ]; then
        local port
        port="${PORT:-8080}"
        sleep 1
        open_browser "http://localhost:${port}"
    fi
}

# ─── Main ───
detect_platform

case "${1:-}" in
    stop)
        stop_service
        ;;
    status)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "Proxy Pulse is running (PID: $(cat "$PID_FILE"))."
        else
            echo "Proxy Pulse is not running."
        fi
        ;;
    update)
        self_update "$@"
        check_binary_update
        echo "Update complete."
        ;;
    *)
        start_service "$@"
        ;;
esac
