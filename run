#!/usr/bin/env bash
# ─────────────────────────────────────────────
#  Proxy Pulse — Run / Stop Script
# ─────────────────────────────────────────────
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUILD_DIR="$SCRIPT_DIR/build"
PID_FILE="$SCRIPT_DIR/.proxy-pulse.pid"

# ─── Detect platform ───
detect_binary() {
    local os arch
    os="$(uname -s | tr '[:upper:]' '[:lower:]')"
    arch="$(uname -m)"

    case "$os" in
        linux)  os="linux" ;;
        darwin) os="darwin" ;;
        *)      echo "Unsupported OS: $os" >&2; exit 1 ;;
    esac

    case "$arch" in
        x86_64|amd64)   arch="amd64" ;;
        aarch64|arm64)  arch="arm64" ;;
        *)              echo "Unsupported architecture: $arch" >&2; exit 1 ;;
    esac

    echo "proxy-pulse-${os}-${arch}"
}

# ─── Stop ───
stop_service() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Proxy Pulse is not running (no PID file found)."
        return 0
    fi

    local pid
    pid="$(cat "$PID_FILE")"

    if kill -0 "$pid" 2>/dev/null; then
        echo "Stopping Proxy Pulse (PID: $pid)..."
        kill "$pid"
        # Wait up to 10 seconds for graceful shutdown
        local i=0
        while kill -0 "$pid" 2>/dev/null && [ $i -lt 10 ]; do
            sleep 1
            i=$((i + 1))
        done
        if kill -0 "$pid" 2>/dev/null; then
            echo "Force killing..."
            kill -9 "$pid" 2>/dev/null || true
        fi
        rm -f "$PID_FILE"
        echo "Proxy Pulse stopped."
    else
        echo "Proxy Pulse is not running (stale PID: $pid)."
        rm -f "$PID_FILE"
    fi
}

# ─── Start ───
start_service() {
    # Check if already running
    if [ -f "$PID_FILE" ]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            echo "Proxy Pulse is already running (PID: $pid)."
            exit 1
        fi
        rm -f "$PID_FILE"
    fi

    local binary_name
    binary_name="$(detect_binary)"
    local binary_path="$BUILD_DIR/$binary_name"

    if [ ! -f "$binary_path" ]; then
        echo "Binary not found: $binary_path" >&2
        echo "Available binaries:" >&2
        ls -1 "$BUILD_DIR"/ 2>/dev/null || echo "  (none)" >&2
        exit 1
    fi

    if [ ! -x "$binary_path" ]; then
        chmod +x "$binary_path"
    fi

    # Copy config.example.yaml to config.yaml if not exists
    if [ ! -f "$SCRIPT_DIR/config.yaml" ]; then
        if [ -f "$SCRIPT_DIR/config.example.yaml" ]; then
            cp "$SCRIPT_DIR/config.example.yaml" "$SCRIPT_DIR/config.yaml"
            echo "Created config.yaml from config.example.yaml — edit it before first use."
        else
            echo "Warning: no config.yaml or config.example.yaml found." >&2
        fi
    fi

    echo "Starting Proxy Pulse ($binary_name)..."
    cd "$SCRIPT_DIR"
    nohup "$binary_path" >> "$SCRIPT_DIR/proxy-pulse.log" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    echo "Proxy Pulse started in background (PID: $pid)."
    echo "Log: $SCRIPT_DIR/proxy-pulse.log"
}

# ─── Main ───
case "${1:-}" in
    stop)
        stop_service
        ;;
    status)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "Proxy Pulse is running (PID: $(cat "$PID_FILE"))."
        else
            echo "Proxy Pulse is not running."
        fi
        ;;
    *)
        start_service
        ;;
esac
