#!/usr/bin/env bash
# ─────────────────────────────────────────────
#  Proxy Pulse — Run / Stop Script
#  Auto-downloads the latest release binary
# ─────────────────────────────────────────────
set -euo pipefail

REPO="OpenInfra-Labs/Proxy-Pulse"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BINARY="$SCRIPT_DIR/proxy-pulse"
PID_FILE="$SCRIPT_DIR/.proxy-pulse.pid"
CONFIG_FILE="$SCRIPT_DIR/config.yaml"
CONFIG_EXAMPLE="$SCRIPT_DIR/config.example.yaml"

# ─── Detect platform ───
detect_artifact() {
    local os arch
    os="$(uname -s | tr '[:upper:]' '[:lower:]')"
    arch="$(uname -m)"

    case "$os" in
        linux)  os="linux" ;;
        darwin) os="darwin" ;;
        *)      echo "Unsupported OS: $os" >&2; exit 1 ;;
    esac

    case "$arch" in
        x86_64|amd64)   arch="amd64" ;;
        aarch64|arm64)  arch="arm64" ;;
        *)              echo "Unsupported architecture: $arch" >&2; exit 1 ;;
    esac

    echo "proxy-pulse-${os}-${arch}"
}

# ─── Download latest release binary ───
download_binary() {
    local artifact="$1"
    local tarball="${artifact}.tar.gz"

    echo "Fetching latest release info..."
    local download_url
    download_url=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
        | grep -o "\"browser_download_url\": *\"[^\"]*${tarball}\"" \
        | head -1 \
        | sed 's/.*"\(https[^"]*\)".*/\1/')

    if [ -z "$download_url" ]; then
        echo "Error: Could not find release asset '${tarball}'" >&2
        echo "Check https://github.com/${REPO}/releases for available downloads." >&2
        exit 1
    fi

    echo "Downloading ${tarball}..."
    curl -fsSL -o "$SCRIPT_DIR/$tarball" "$download_url"

    echo "Extracting..."
    tar xzf "$SCRIPT_DIR/$tarball" -C "$SCRIPT_DIR"
    mv "$SCRIPT_DIR/$artifact" "$BINARY"
    chmod +x "$BINARY"
    rm -f "$SCRIPT_DIR/$tarball"
    echo "Binary downloaded: $BINARY"
}

# ─── Download config.example.yaml from repo ───
download_config_example() {
    echo "Downloading config.example.yaml..."
    curl -fsSL -o "$CONFIG_EXAMPLE" \
        "https://raw.githubusercontent.com/${REPO}/main/config.example.yaml"
    echo "Config template downloaded: $CONFIG_EXAMPLE"
}

# ─── Ensure binary exists ───
ensure_binary() {
    if [ ! -f "$BINARY" ]; then
        local artifact
        artifact="$(detect_artifact)"
        download_binary "$artifact"
    fi
}

# ─── Ensure config exists ───
ensure_config() {
    if [ ! -f "$CONFIG_EXAMPLE" ]; then
        download_config_example
    fi
    if [ ! -f "$CONFIG_FILE" ]; then
        cp "$CONFIG_EXAMPLE" "$CONFIG_FILE"
        echo "Config: created config.yaml from config.example.yaml (default settings)."
    fi
}

# ─── Update binary to latest ───
update_binary() {
    local artifact
    artifact="$(detect_artifact)"
    echo "Updating to latest release..."
    download_binary "$artifact"
    echo "Update complete."
}

# ─── Stop ───
stop_service() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Proxy Pulse is not running (no PID file found)."
        return 0
    fi

    local pid
    pid="$(cat "$PID_FILE")"

    if kill -0 "$pid" 2>/dev/null; then
        echo "Stopping Proxy Pulse (PID: $pid)..."
        kill "$pid"
        local i=0
        while kill -0 "$pid" 2>/dev/null && [ $i -lt 10 ]; do
            sleep 1
            i=$((i + 1))
        done
        if kill -0 "$pid" 2>/dev/null; then
            echo "Force killing..."
            kill -9 "$pid" 2>/dev/null || true
        fi
        rm -f "$PID_FILE"
        echo "Proxy Pulse stopped."
    else
        echo "Proxy Pulse is not running (stale PID: $pid)."
        rm -f "$PID_FILE"
    fi
}

# ─── Start ───
start_service() {
    if [ -f "$PID_FILE" ]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            echo "Proxy Pulse is already running (PID: $pid)."
            exit 1
        fi
        rm -f "$PID_FILE"
    fi

    ensure_binary
    ensure_config

    echo "Starting Proxy Pulse..."
    cd "$SCRIPT_DIR"
    nohup "$BINARY" >> "$SCRIPT_DIR/proxy-pulse.log" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    echo "Proxy Pulse started in background (PID: $pid)."
    echo "Log: $SCRIPT_DIR/proxy-pulse.log"
}

# ─── Main ───
case "${1:-}" in
    stop)
        stop_service
        ;;
    status)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "Proxy Pulse is running (PID: $(cat "$PID_FILE"))."
        else
            echo "Proxy Pulse is not running."
        fi
        ;;
    update)
        update_binary
        ;;
    *)
        start_service
        ;;
esac
