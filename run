#!/usr/bin/env bash
# ─────────────────────────────────────────────
#  Proxy Pulse — Run / Stop Script
#  Auto-downloads the latest release binary
#  Self-updates when a newer version is available
# ─────────────────────────────────────────────
set -euo pipefail

REPO="OpenInfra-Labs/Proxy-Pulse"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT_PATH="$SCRIPT_DIR/$(basename "$0")"
BINARY="$SCRIPT_DIR/proxy-pulse"
PID_FILE="$SCRIPT_DIR/.proxy-pulse.pid"
CONFIG_FILE="$SCRIPT_DIR/config.yaml"
CONFIG_EXAMPLE="$SCRIPT_DIR/config.example.yaml"
VERSION_FILE="$SCRIPT_DIR/.proxy-pulse.version"

# ─── Detect platform ───
detect_artifact() {
    local os arch
    os="$(uname -s | tr '[:upper:]' '[:lower:]')"
    arch="$(uname -m)"

    case "$os" in
        linux)  os="linux" ;;
        darwin) os="darwin" ;;
        *)      echo "Unsupported OS: $os" >&2; exit 1 ;;
    esac

    case "$arch" in
        x86_64|amd64)   arch="amd64" ;;
        aarch64|arm64)  arch="arm64" ;;
        *)              echo "Unsupported architecture: $arch" >&2; exit 1 ;;
    esac

    echo "proxy-pulse-${os}-${arch}"
}

# ─── Self-update: check if run script itself has a newer version ───
self_update() {
    echo "Checking for run script updates..."
    local remote_url="https://raw.githubusercontent.com/${REPO}/main/run"
    local tmp_script
    tmp_script="$(mktemp)"

    if ! curl -fsSL -o "$tmp_script" "$remote_url"; then
        echo "Warning: Could not check for script updates." >&2
        rm -f "$tmp_script"
        return 0
    fi

    if ! diff -q "$SCRIPT_PATH" "$tmp_script" > /dev/null 2>&1; then
        echo "Run script has been updated. Applying update..."
        cp "$tmp_script" "$SCRIPT_PATH"
        chmod +x "$SCRIPT_PATH"
        rm -f "$tmp_script"
        echo "Restarting with updated script..."
        exec "$SCRIPT_PATH" "$@"
    fi

    rm -f "$tmp_script"
    echo "Run script is up to date."
}

# ─── Get latest release tag from GitHub ───
get_latest_version() {
    curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
        | grep '"tag_name"' \
        | head -1 \
        | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/'
}

# ─── Download release binary for a specific version ───
download_binary() {
    local artifact="$1"
    local version="$2"
    local tarball="${artifact}.tar.gz"
    local download_url="https://github.com/${REPO}/releases/download/${version}/${tarball}"

    echo "Downloading ${tarball} (${version})..."
    if ! curl -fsSL -o "$SCRIPT_DIR/$tarball" "$download_url"; then
        echo "Error: Failed to download ${download_url}" >&2
        exit 1
    fi

    echo "Extracting..."
    tar xzf "$SCRIPT_DIR/$tarball" -C "$SCRIPT_DIR"
    mv "$SCRIPT_DIR/$artifact" "$BINARY"
    chmod +x "$BINARY"
    rm -f "$SCRIPT_DIR/$tarball"

    # Save installed version
    echo "$version" > "$VERSION_FILE"
    echo "Binary installed: $BINARY (${version})"
}

# ─── Download config.example.yaml from repo ───
download_config_example() {
    echo "Downloading config.example.yaml..."
    curl -fsSL -o "$CONFIG_EXAMPLE" \
        "https://raw.githubusercontent.com/${REPO}/main/config.example.yaml"
    echo "Config template downloaded: $CONFIG_EXAMPLE"
}

# ─── Check and update binary if a newer version is available ───
check_binary_update() {
    local latest_version
    latest_version="$(get_latest_version)"

    if [ -z "$latest_version" ]; then
        echo "Warning: Could not fetch latest version info." >&2
        return 0
    fi

    # No binary or no version file → download
    if [ ! -f "$BINARY" ] || [ ! -f "$VERSION_FILE" ]; then
        local artifact
        artifact="$(detect_artifact)"
        download_binary "$artifact" "$latest_version"
        return 0
    fi

    local current_version
    current_version="$(cat "$VERSION_FILE")"

    if [ "$current_version" != "$latest_version" ]; then
        echo "New version available: ${current_version} → ${latest_version}"
        local artifact
        artifact="$(detect_artifact)"
        download_binary "$artifact" "$latest_version"
    else
        echo "Binary is up to date (${current_version})."
    fi
}

# ─── Ensure config exists ───
ensure_config() {
    if [ ! -f "$CONFIG_EXAMPLE" ]; then
        download_config_example
    fi
    if [ ! -f "$CONFIG_FILE" ]; then
        cp "$CONFIG_EXAMPLE" "$CONFIG_FILE"
        echo "Config: created config.yaml from config.example.yaml (default settings)."
    fi
}

# ─── Stop ───
stop_service() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Proxy Pulse is not running (no PID file found)."
        return 0
    fi

    local pid
    pid="$(cat "$PID_FILE")"

    if kill -0 "$pid" 2>/dev/null; then
        echo "Stopping Proxy Pulse (PID: $pid)..."
        kill "$pid"
        local i=0
        while kill -0 "$pid" 2>/dev/null && [ $i -lt 10 ]; do
            sleep 1
            i=$((i + 1))
        done
        if kill -0 "$pid" 2>/dev/null; then
            echo "Force killing..."
            kill -9 "$pid" 2>/dev/null || true
        fi
        rm -f "$PID_FILE"
        echo "Proxy Pulse stopped."
    else
        echo "Proxy Pulse is not running (stale PID: $pid)."
        rm -f "$PID_FILE"
    fi
}

# ─── Start ───
start_service() {
    if [ -f "$PID_FILE" ]; then
        local pid
        pid="$(cat "$PID_FILE")"
        if kill -0 "$pid" 2>/dev/null; then
            echo "Proxy Pulse is already running (PID: $pid)."
            exit 1
        fi
        rm -f "$PID_FILE"
    fi

    # Self-update the run script first
    self_update "$@"

    # Check for binary updates (download or upgrade)
    check_binary_update

    # Ensure config
    ensure_config

    echo "Starting Proxy Pulse..."
    cd "$SCRIPT_DIR"
    nohup "$BINARY" >> "$SCRIPT_DIR/proxy-pulse.log" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    echo "Proxy Pulse started in background (PID: $pid)."
    echo "Log: $SCRIPT_DIR/proxy-pulse.log"
}

# ─── Main ───
case "${1:-}" in
    stop)
        stop_service
        ;;
    status)
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "Proxy Pulse is running (PID: $(cat "$PID_FILE"))."
        else
            echo "Proxy Pulse is not running."
        fi
        ;;
    update)
        self_update "$@"
        check_binary_update
        echo "Update complete."
        ;;
    *)
        start_service "$@"
        ;;
esac
